import 'package:flutter/material.dart';

void main() => runApp(MaterialApp(home: CartPage()));

class CartPage extends StatefulWidget {
  @override
  _CartPageState createState() => _CartPageState();
}

class _CartPageState extends State<CartPage> {
  List<Map> products = [
    {'name': 'Item 1', 'price': 100, 'qty': 0},
    {'name': 'Item 2', 'price': 200, 'qty': 0},
    {'name': 'Item 3', 'price': 150, 'qty': 0},
  ];

  int total = 0;

  void updateTotal() {
    total = 0;
    for (var p in products) {
      total += p['price'] as int * p['qty'] as int;
    }
  }

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      appBar: AppBar(title: Text("Shopping Cart")),
      body: Column(
        children: [
          Expanded(
            child: GridView.count(
              crossAxisCount: 2,
              children: products.map((p) {
                return Card(
                  child: Column(
                    children: [
                      Text(p['name']),
                      Text("₹${p['price']}"),
                      Row(
                        mainAxisAlignment: MainAxisAlignment.center,
                        children: [
                          IconButton(
                            icon: Icon(Icons.remove),
                            onPressed: () {
                              setState(() {
                                if (p['qty'] > 0) p['qty']--;
                                updateTotal();
                              });
                            },
                          ),
                          Text("${p['qty']}"),
                          IconButton(
                            icon: Icon(Icons.add),
                            onPressed: () {
                              setState(() {
                                p['qty']++;
                                updateTotal();
                              });
                            },
                          ),
                        ],
                      )
                    ],
                  ),
                );
              }).toList(),
            ),
          ),
          Text("Total: ₹$total", style: TextStyle(fontSize: 20))
        ],
      ),
    );
  }
}
