import 'package:flutter/material.dart';

void main() => runApp(MaterialApp(home: FontPage()));

class FontPage extends StatefulWidget {
  @override
  _FontPageState createState() => _FontPageState();
}

class _FontPageState extends State<FontPage> {
  double size = 20;
  String font = "Arial";
  bool bold = false, italic = false, underline = false;

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      appBar: AppBar(title: Text("Font Selector")),
      body: Column(
        children: [
          Slider(
            value: size,
            min: 10,
            max: 50,
            onChanged: (val) => setState(() => size = val),
          ),

          DropdownButton(
            value: font,
            items: ["Arial", "Courier", "Times"].map((f) {
              return DropdownMenuItem(value: f, child: Text(f));
            }).toList(),
            onChanged: (val) => setState(() => font = val!),
          ),

          CheckboxListTile(
            title: Text("Bold"),
            value: bold,
            onChanged: (val) => setState(() => bold = val!),
          ),
          CheckboxListTile(
            title: Text("Italic"),
            value: italic,
            onChanged: (val) => setState(() => italic = val!),
          ),
          CheckboxListTile(
            title: Text("Underline"),
            value: underline,
            onChanged: (val) => setState(() => underline = val!),
          ),

          ElevatedButton(
            child: Text("Show"),
            onPressed: () {
              setState(() {});
            },
          ),

          Text(
            "Sample Text",
            style: TextStyle(
              fontSize: size,
              fontWeight: bold ? FontWeight.bold : FontWeight.normal,
              fontStyle: italic ? FontStyle.italic : FontStyle.normal,
              decoration:
                  underline ? TextDecoration.underline : TextDecoration.none,
            ),
          )
        ],
      ),
    );
  }
}
